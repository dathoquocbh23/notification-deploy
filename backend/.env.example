# Copy thành .env (hoặc export trước khi chạy). KHÔNG commit file .env thật.
DB_URL=jdbc:postgresql://localhost:5432/notify_demo
DB_USER=postgres
DB_PASSWORD=postgres

# Gmail: bật 2FA -> tạo App Password tại https://myaccount.google.com/apppasswords
MAIL_USER=yourapp@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Firebase service account (chỉ dùng để gọi FCM — KHÔNG dùng dịch vụ Firebase nào khác)
# Firebase Console -> Project settings -> Service accounts -> Generate new private key
FIREBASE_SA_PATH=./service-account.json
